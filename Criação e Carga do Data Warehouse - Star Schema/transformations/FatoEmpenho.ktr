    <connection>tceDW</connection>
    <sql>SELECT
    COALESCE(dt.sk_tempo, 0)            AS sk_tempo,
    COALESCE(de.sk_estrutura_admin, 0)  AS sk_estrutura_admin,
    COALESCE(dfo.sk_fornecedor, 0)      AS sk_fornecedor,
    COALESCE(dpa.sk_programa_acao, 0)   AS sk_programa_acao,
    COALESCE(dfr.sk_fonte_recurso, 0)   AS sk_fonte_recurso,
    COALESCE(dl.sk_licitacao, 0)        AS sk_licitacao,
    SUM(e.valor_empenhado)              AS valor_empenhado,
    SUM(e.valor_liquidado)              AS valor_liquidado,
    SUM(e.valor_pago)                   AS valor_pago,
    (SUM(e.valor_empenhado) - SUM(e.valor_pago)) AS saldo_a_pagar
FROM (
    SELECT 
        data_empenho,
        unidade_gestora_id,
        unidade_orcamentaria_id,
        credor_id,
        acao_id,
        fonte_recurso_id,
        licitacao_id,
        SUM(COALESCE(valor_empenhado, 0)) AS valor_empenhado,
        SUM(COALESCE(valor_liquidado, 0)) AS valor_liquidado,
        SUM(COALESCE(valor_pago, 0))      AS valor_pago
    FROM tce_pb.empenho
    GROUP BY 
        data_empenho,
        unidade_gestora_id,
        unidade_orcamentaria_id,
        credor_id,
        acao_id,
        fonte_recurso_id,
        licitacao_id
) e
LEFT JOIN tce_pb_dw.dim_tempo dt 
       ON dt.data = e.data_empenho

LEFT JOIN tce_pb.unidade_gestora ug 
       ON e.unidade_gestora_id = ug.id_unidade_gestora
LEFT JOIN tce_pb.unidade_orcamentaria uo 
       ON e.unidade_orcamentaria_id = uo.id_unidade_orcamentaria
LEFT JOIN tce_pb_dw.dim_estrutura_administrativa de
       ON de.codigo_unidade_gestora = ug.codigo_unidade_gestora
      AND de.codigo_unidade_orcamentaria = uo.codigo_unidade_orcamentaria

LEFT JOIN tce_pb.fornecedor f 
       ON e.credor_id = f.id_fornecedor
LEFT JOIN tce_pb_dw.dim_fornecedor dfo 
       ON dfo.cpf_cnpj = f.cpf_cnpj

LEFT JOIN tce_pb.acao a 
       ON e.acao_id = a.id_acao
LEFT JOIN tce_pb.programa p 
       ON a.programa_id = p.id_programa
LEFT JOIN tce_pb_dw.dim_programa_acao dpa
       ON dpa.codigo_programa = p.codigo_programa
      AND dpa.codigo_acao = a.codigo_acao

LEFT JOIN tce_pb.fonte_recurso fr 
       ON e.fonte_recurso_id = fr.id_fonte_recurso
LEFT JOIN tce_pb_dw.dim_fonte_recurso dfr
       ON dfr.codigo_fonte_recurso = fr.codigo_fonte_recurso
      AND dfr.ano_fonte = fr.ano_fonte

LEFT JOIN tce_pb.licitacao l 
       ON e.licitacao_id = l.id_licitacao
LEFT JOIN tce_pb_dw.dim_licitacao dl
       ON dl.numero_licitacao = l.numero_licitacao
      AND dl.numero_protocolo_tce = l.numero_protocolo_tce

GROUP BY 
    COALESCE(dt.sk_tempo, 0), 
    COALESCE(de.sk_estrutura_admin, 0), 
    COALESCE(dfo.sk_fornecedor, 0), 
    COALESCE(dpa.sk_programa_acao, 0), 
    COALESCE(dfr.sk_fonte_recurso, 0), 
    COALESCE(dl.sk_licitacao, 0);</sql>
