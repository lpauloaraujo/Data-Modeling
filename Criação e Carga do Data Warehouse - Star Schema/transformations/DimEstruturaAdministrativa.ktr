    <connection>tceDW</connection>
    <sql>SELECT 
  codigo_unidade_gestora
, descricao_unidade_gestora
, nome_municipio
, codigo_unidade_orcamentaria
, descricao_unidade_orcamentaria
FROM tce_pb.unidade_gestora u 
LEFT JOIN tce_pb.municipio m 
    ON m.id_municipio = u.municipio_id
LEFT JOIN tce_pb.empenho e 
    ON e.unidade_gestora_id = u.id_unidade_gestora
LEFT JOIN tce_pb.unidade_orcamentaria o
    ON e.unidade_orcamentaria_id = o.id_unidade_orcamentaria
GROUP BY 
  codigo_unidade_gestora
, descricao_unidade_gestora
, nome_municipio
, codigo_unidade_orcamentaria
, descricao_unidade_orcamentaria;</sql>
    <limit>0</limit>
